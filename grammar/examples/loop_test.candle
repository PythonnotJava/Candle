// loop_test.candle - 循环测试（Candle 风格：int main 入口）

int main() {
    // for iter
    for iter(i, 5) {
        print(i);
    }

    // for iter 带范围
    for iter(i, 3, 8) {
        print(i);
    }

    // for iter 遍历列表
    list items = ["a", "b", "c"];
    for iter(x, items) {
        print(x);
    }

    // 嵌套循环
    for iter(i, 3) {
        for iter(j, 3) {
            print(f"{i},{j}");
        }
    }

    // when 循环
    alias n = 0;
    when (n < 5) {
        print(n);
        n = n + 1;
    }

    // break
    for iter(i, 100) {
        if (i == 10) {
            break;
        }
        print(i);
    }

    return 0;
}
