// inherit_test.candle - 继承测试（Candle 风格：int main 入口）

class Shape {
    string name;
    Shape(string name);

    string describe() {
        return name;
    }

    double area() {
        return 0.0;
    }
}

class Circle inherit Shape {
    double radius;
    Circle(super.name, double radius);

    double area() {
        return 3.14159 * radius * radius;
    }
}

class Square inherit Shape {
    double side;
    Square(super.name, double side);

    double area() {
        return side * side;
    }
}

int main() {
    alias c = Circle("circle", 5.0);
    print(c.describe());
    print(c.area());

    alias s = Square("square", 4.0);
    print(s.describe());
    print(s.area());

    return 0;
}
