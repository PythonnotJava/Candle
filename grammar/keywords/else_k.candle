/// else: 与 if 配合的条件分支，可级联 else if

int classify(int x) {
    if (x < 0) {
        return -1;
    } else if (x == 0) {
        return 0;
    } else if (x < 10) {
        return 1;
    } else {
        return 2;
    }
}

int main() {
    print(classify(-5));
    print(classify(0));
    print(classify(7));
    print(classify(100));
    return 0;
}
