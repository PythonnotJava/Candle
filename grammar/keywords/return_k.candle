/// return: 从函数/方法返回值，void 函数可直接 return;

int add(int a, int b) {
    return a + b;
}

void greet(string name) {
    if (name == '') {
        return;             // 提前返回，无值
    }
    print(f'hello, {name}');
}

int firstPositive(list xs) {
    for iter(x, xs) {
        if (x > 0) {
            return x;       // 早期返回
        }
    }
    return -1;
}

int main() {
    print(add(3, 4));
    greet('');
    greet('Candle');
    print(firstPositive([-3, -1, 0, 5, 8]));
    return 0;
}
