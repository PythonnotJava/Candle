/// false: 布尔假值字面量

int main() {
    bool flag = false;
    print(flag);

    if (!flag) {
        print('flag is false');
    }

    // 与逻辑运算
    bool a = false && true;     // false
    bool b = false || true;     // true
    print(a);
    print(b);

    // 与比较
    print(1 == 2);              // false
    return 0;
}
