/// Map — Candle 映射类型标准库（reflect 扩展）
/// 方法体用纯 Candle 实现。运行时优先 reflect → 回退 C 内置 map_method。
///
/// 使用: load library.std.Map 后即可在任意 map 值上调用

export { };

reflect map {
    int size() {
        return len(self);
    }

    bool isEmpty() {
        return len(self) == 0;
    }

    bool isNotEmpty() {
        return len(self) > 0;
    }

    bool containsKey(string key) {
        return self[key] != null;
    }
}
