/// Double — Candle 浮点类型标准库（reflect 扩展）
/// 方法体用纯 Candle 实现。运行时优先 reflect → 回退 C 内置 num_method。
///
/// C 内置回退方法（不需要 reflect）:
///   floor/ceil/round/truncate/isFinite/isNaN/toInt — 在 num_method 中已实现
///
/// 使用: load library.std.Double 后即可在任意 double 值上调�?

export { };

reflect double {
    // ── 符号与状态 ──

    /// 是否为正数（> 0）
    bool isPositive() {
        return self > 0;
    }

    /// 是否为负（< 0）
    bool isNegative() {
        return self < 0;
    }

    /// 是否为�?
    bool isZero() {
        return self == 0;
    }

    /// 是否为整数（小数部分为�?
    bool isInteger() {
        return self == self.toInt();
    }

    // ── 符号 ──

    /// 符号：正 → 1，负 → -1，零 → 0
    int sign() {
        if (self > 0) { return 1; }
        if (self < 0) { return -1; }
        return 0;
    }

    // ── 数值 ──

    /// 绝对�?
    double abs() {
        if (self < 0) { return -self; }
        return self;
    }

    /// 倒数
    double reciprocal() {
        return 1.0 / self;
    }

    /// 平�?
    double squared() {
        return self * self;
    }

    /// 立�?
    double cubed() {
        return self * self * self;
    }

    // ── 钳制 ──

    /// 限制在 [lo, hi] 范围内
    double clamp(double lo, double hi) {
        if (self < lo) { return lo; }
        if (self > hi) { return hi; }
        return self;
    }

    // ── 类型转换 ──

    /// 自身
    double toDouble() {
        return self;
    }

    /// 转字符串
    string toString() {
        return String(self);
    }
}
