/// main_aot.candle — 多文件 AOT 编译测试（仅 AOT 兼容特性）
/// 解释执行: candlec --run main_aot.candle
/// AOT 编译: candlec -c main_aot.candle && main_aot.exe

load test.compile_test_all.mod_add;
load test.compile_test_all.math_utils;
load test.compile_test_all.control_flow;

int main() {
    print("=== Multi-File AOT Test ===");

    // mod_add 模块
    print(mod_add.add(10, 20));
    print(mod_add.multiply(7, 8));

    // math_utils 模块（带递归）
    print(math_utils.add(3, 4));
    print(math_utils.factorial(5));
    print(math_utils.isPrime(13));

    // control_flow 模块（带 if/for/递归）
    print(control_flow.testIf(15));
    print(control_flow.testIf(-5));
    print(control_flow.testFor(6));
    print(control_flow.testFib(7));

    print("=== ALL MULTI-FILE AOT PASSED ===");
    return 0;
}
