/// http_debug.candle — HTTP GET + POST 验证

load std.http;

int main() {
    print("=== HTTP Test ===");

    alias r1 = http.get("http://www.baidu.com/");
    print("GET baidu: " + String(len(r1)));

    alias r2 = http.post("http://httpbin.org/post", "hello=world");
    print("POST httpbin: " + String(len(r2)));

    alias r3 = http.get("http://httpbin.org/get");
    print("GET httpbin: " + String(len(r3)));

    print("=== HTTP PASSED ===");
    return 0;
}
