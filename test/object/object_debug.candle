int main() {
    // Test: does type() work on basic types?
    print(type(42));        // int
    print(type(3.14));      // double
    print(type("hi"));      // string
    
    // Test: does String() work?
    print(String(42));
    print(String(true));
    
    print("DEBUG DONE");
    return 0;
}
