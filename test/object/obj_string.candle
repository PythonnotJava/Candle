class TestA { int x; }

int main() {
    alias a = TestA();
    a.x = 99;
    print(a.x);              // should be 99

    // Does String() work on objects?
    print(String(a));        // should print "Instance of TestA"

    // Does type() work?
    print(type(a));          // should be "object"

    print("DONE");
    return 0;
}
