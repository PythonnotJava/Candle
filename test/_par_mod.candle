int main() {
    parallel {
        section {
            for iter(n, 2, 100) {
                if (n >= 2) {
                    int isPrime = 1;
                    for iter(d, 2, n/2+1) {
                        if (n % d == 0) { isPrime = 0; break; }
                    }
                }
            }
        }
        section {
            for iter(n, 100, 200) {
                if (n >= 2) {
                    int isPrime = 1;
                    for iter(d, 2, n/2+1) {
                        if (n % d == 0) { isPrime = 0; break; }
                    }
                }
            }
        }
    }
    print("done");
    return 0;
}
