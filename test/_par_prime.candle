load std.time alias time;
int countPrimes(int start, int end) {
    int count = 0;
    for iter(n, start, end) {
        if (n >= 2) {
            int isPrime = 1;
            int limit = n / 2 + 1;
            for iter(d, 2, limit) {
                if (n % d == 0) { isPrime = 0; break; }
            }
            if (isPrime == 1) { count = count + 1; }
        }
    }
    return count;
}
int main() {
    parallel {
        section { alias c = countPrimes(2, 100); }
        section { alias c = countPrimes(100, 200); }
    }
    print("done");
    return 0;
}
