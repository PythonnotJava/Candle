// json_test.candle

load std.json alias json;

int main() {
    map m1 = { 'x': 10 };
    if (m1.get('x') == 10) { print('inline map: OK'); }

    alias obj = json.parse('{"x":10}');
    print(type(obj));
    if (obj.get('x') == 10) { print('json.get int: OK'); }
    else { print('json.get int: FAIL'); }

    alias arr = json.parse('[1,2,3]');
    if (arr.get(1) == 2) { print('json arr.get: OK'); }
    else { print('json arr.get: FAIL'); }

    print('JSON TESTS PASSED');
    return 0;
}
