/// Win32 GUI test — MessageBox, Beep, flash window
/// WARNING: pops up a dialog that auto-closes after brief display
/// Uses: user32.dll (MessageBoxA), kernel32.dll (Beep, Sleep)

// 1. Load DLLs
dll system.user32 alias u32;
dll system.kernel32 alias k32;

// 2. Declare FFI signatures
ellipsis int MessageBoxA(int hwnd, string text, string caption, int type);
ellipsis int Beep(int freq, int duration);
ellipsis void Sleep(int ms);
ellipsis int GetTickCount();

int main() {
    int MB_OK = 0;
    int MB_ICONINFORMATION = 0x40;

    // Beep: play a system beep (non-blocking on modern Windows)
    alias beep_ret = Beep(800, 200);
    print("Beep(800,200):");
    print(beep_ret);

    // Time check
    alias t1 = GetTickCount();
    Sleep(50);
    alias t2 = GetTickCount();
    print("Slept 50ms, actual:");
    print(t2 - t1);

    // MessageBox: interactive dialog
    print("Displaying MessageBox... (click OK to continue)");
    alias ret = MessageBoxA(0, "Candle FFI is working!\n\nThis is a Win32 MessageBoxA call", "Candle Win32 GUI", MB_OK + MB_ICONINFORMATION);
    print("MessageBox returned:");
    print(ret);

    print("WIN32 GUI TEST COMPLETE");
    return 0;
}
