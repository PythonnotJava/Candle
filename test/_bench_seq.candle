load std.time alias time;
int countPrimes(int start, int end) {
    int count = 0;
    for iter(n, start, end) {
        if (n < 2) { continue; }
        int isPrime = 1;
        int limit = n / 2 + 1;
        for iter(d, 2, limit) {
            if (n % d == 0) { isPrime = 0; break; }
        }
        if (isPrime == 1) { count = count + 1; }
    }
    return count;
}
int main() {
    alias N = 100;
    alias s_result = countPrimes(2, N);
    print("primes=" + String(s_result));
    return 0;
}
