int worker(int n) { return n * 2; }
int main() {
    int a = 0; int b = 0; int c = 0; int d = 0;
    parallel {
        section { a = worker(10); }
        section { b = worker(20); }
        section { c = worker(30); }
        section { d = worker(40); }
    }
    print("a=" + String(a) + " b=" + String(b) + " c=" + String(c) + " d=" + String(d));
    return 0;
}
