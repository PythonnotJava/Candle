int main() {
    map m = {"a": 1, "b": 2};

    // 修改已有键的值（通过 []）
    m["a"] = 100;
    print(m["a"]);

    // 通过 set 方法
    m.set("b", 200);
    print(m["b"]);

    // 新增键
    m["c"] = 300;
    print(m["c"]);

    // 删除键
    alias removed = m.remove("a");
    print(removed);
    print(m.containsKey("a"));

    // keys / values
    alias ks = m.keys();
    print(ks.join(","));
    print(m.size());

    print("OK");
    return 0;
}
