load library.std.Double alias _;
load library.std.Int alias _;
load library.std.Bool alias _;

int main() {
    // Double methods
    print(3.14.isPositive());
    print((-5.5).isNegative());
    print(0.0.isZero());
    print((-3.14).abs());
    print(2.0.squared());
    print(2.0.cubed());
    print(5.0.clamp(2.0, 4.0));

    // Int methods
    int x = 42;
    print(x.isEven());
    print(x.sign());
    print(x.abs());
    print(x.clamp(0, 10));

    // Bool methods
    bool t = true;
    print(t.toggle());
    print(t.toInt());

    print("AOT LOAD TEST PASSED");
    return 0;
}
