class A { }
class B inherit A { }

int main() {
    print(is(B, "A"));
    print(is(B, "Object"));
    print(is(A, "Object"));
    print(is(B, "B"));
    print(is(A, "B"));

    alias b = B();
    print(is(b, "B"));
    print(is(b, "A"));
    print(is(b, "Object"));

    print("ISA_CLASS OK");
    print(b.hashCode());
    print(b.toString());
    print(b.type());
    return 0;
}
