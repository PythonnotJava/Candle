load std.time alias time;

int main() {
    print("=== Candle Parallel Benchmark ===");

    alias N = 10000000;
    int a = 0;
    int b = 0;

    alias t1 = time.now();
    for iter(i, N) { a = a + 1; }
    for iter(i, N) { b = b + 1; }
    alias t2 = time.now();
    alias seq_ms = t2 - t1;
    print("Sequential:     " + String(seq_ms) + " ms  (a=" + String(a) + ", b=" + String(b) + ")");

    int c = 0;
    int d = 0;
    alias t3 = time.now();
    parallel {
        { for iter(i, N) { c = c + 1; } }
        { for iter(i, N) { d = d + 1; } }
    }
    alias t4 = time.now();
    alias par_ms = t4 - t3;
    print("Parallel (2):   " + String(par_ms) + " ms  (c=" + String(c) + ", d=" + String(d) + ")");

    alias speedup = seq_ms / par_ms;
    print("Speedup: " + String(speedup) + "x");

    if (c == N && d == N) {
        print("PARALLEL BENCH PASSED");
    } else {
        print("PARALLEL BENCH FAILED (c=" + String(c) + " d=" + String(d) + ")");
    }
    return 0;
}
