int main() {
    parallel {
        section {
            for iter(n, 2, 100) {
                int limit = n / 2 + 1;
                for iter(d, 2, limit) {
                    if (n % d == 0) { break; }
                }
            }
        }
        section {
            for iter(n, 100, 200) {
                int limit = n / 2 + 1;
                for iter(d, 2, limit) {
                    if (n % d == 0) { break; }
                }
            }
        }
    }
    print("done");
    return 0;
}
