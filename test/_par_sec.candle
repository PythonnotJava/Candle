int main() {
    int a = 0;
    int b = 0;
    int c = 0;
    int d = 0;
    parallel {
        section { for iter(i, 1000) { a = a + 1; } }
        section { for iter(i, 1000) { b = b + 1; } }
        section { for iter(i, 1000) { c = c + 1; } }
        section { for iter(i, 1000) { d = d + 1; } }
    }
    print("a=" + String(a));
    print("b=" + String(b));
    print("c=" + String(c));
    print("d=" + String(d));
    return 0;
}
