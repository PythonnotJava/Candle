/// test_map_stdlib.candle — Map 标准库测试
// load library.std.Map;

int main() {
    alias m = {"a": "1", "b": "2", "c": "3"};

    // putIfAbsent
    m.putIfAbsent("a", "999");
    print(m.get("a"));
    m.putIfAbsent("d", "4");
    print(m.get("d"));

    // keyList / valueList
    print(len(m.keyList()));

    // mapValues
    alias doubled = m.mapValues((v) => v + v);
    print(doubled.get("a"));

    // filterEntries
    alias filtered = m.filterEntries((k, v) => v == "3");
    print(filtered.containsKey("a"));
    print(filtered.containsKey("c"));

    // removeWhere
    m.removeWhere((k, v) => v == "2");
    print(m.containsKey("b"));

    // putAll
    map m2 = {"x": "10", "y": "20"};
    m.putAll(m2);
    print(m.get("x"));
    print(m.get("y"));

    // forEach
    m.forEach((k, v) => print(k));

    m[345] = 434;
    print(m);

     m[345] = 4314;
    print(m);
    print(type(m));

    print("MAP STDLIB TESTS PASSED");

    alias l = [123, "sds", true, 123.2];
    print(l);
    print(type(l));

    print(is(Iterable, "Object"))   ;
        print(is(Iterable, Object))   ;
        load std.math;
        print(math.PI);
        print(math.cos(math.PI / 4));
        print(math.PI / 2);
    return 0;
}
