int main() {
    int r = 0;
    parallel {
        section {
            for iter(i, 10) {
                for iter(j, 10) {
                    if (j == 5) { break; }
                    r = r + 1;
                }
            }
        }
        section {
            for iter(i, 10) {
                for iter(j, 10) {
                    if (j == 5) { break; }
                    r = r + 1;
                }
            }
        }
    }
    print("r=" + String(r));
    return 0;
}
